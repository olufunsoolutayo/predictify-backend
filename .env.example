NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/predictify

# JWT
JWT_SECRET=replace-with-32+byte-random-string
JWT_ISSUER=predictify
JWT_AUDIENCE=predictify-app
JWT_TTL_SECONDS=3600

# Stellar
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
PREDICTIFY_CONTRACT_ID=CABCDEF...

# Indexer
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_START_LEDGER=0
INDEXER_REWIND_LEDGERS=100
INDEXER_GAP_SCAN_INTERVAL_MS=60000
INDEXER_BACKFILL_CHUNK_SIZE=1000
